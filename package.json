{
  "name": "tshell",
  "displayName": "tshell",
  "description": "SSH/SFTP client for running Linux commands and transferring files without server-side setup.",
  "version": "0.1.5",
  "publisher": "tora-zhren",
  "license": "MIT",
  "icon": "media/tshell.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/renzhenghui0814-pixel/tshell.git"
  },
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:tshell.view",
    "onCommand:tshell.focus"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tshell.focus",
        "title": "tshell: Open"
      },
      {
        "command": "tshell.openConfig",
        "title": "tshell: Open Config File"
      },
      {
        "command": "tshell.copySession",
        "title": "%command.copySession.title%"
      },
      {
        "command": "tshell.renameSession",
        "title": "%command.renameSession.title%"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tshell",
          "title": "tshell",
          "icon": "media/ssh.svg"
        }
      ]
    },
    "views": {
      "tshell": [
        {
          "id": "tshell.view",
          "name": "tshell",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "tshell.openConfig",
          "when": "view == tshell.view",
          "group": "navigation"
        }
      ],
      "editor/title/context": [
        {
          "command": "tshell.copySession",
          "when": "activeWebviewPanelId == 'tshell.terminal'",
          "group": "navigation"
        },
        {
          "command": "tshell.renameSession",
          "when": "activeWebviewPanelId == 'tshell.terminal'",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "iconv-lite": "^0.7.2",
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/ssh2": "^1.15.5",
    "@types/vscode": "^1.92.0",
    "@vscode/vsce": "^3.2.1",
    "typescript": "^5.5.4"
  }
}
